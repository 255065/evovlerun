# ---------------------------------------------------------------
# App
# ---------------------------------------------------------------
ENV=development
LOG_LEVEL=INFO

# Comma-separated origins allowed to call the API.
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------
# From Supabase → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
# Service role key — server-only. NEVER expose to the frontend.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
# JWT secret used to verify Supabase access tokens (from Settings → API → JWT Settings)
SUPABASE_JWT_SECRET=YOUR-JWT-SECRET

# ---------------------------------------------------------------
# Anthropic
# ---------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Models to use per task type
ANTHROPIC_MODEL_REASONING=claude-sonnet-4-6
ANTHROPIC_MODEL_DEEP=claude-opus-4-7
ANTHROPIC_MODEL_BULK=claude-haiku-4-5

# ---------------------------------------------------------------
# Token encryption (OAuth tokens for Garmin/Strava/etc.)
# ---------------------------------------------------------------
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=GENERATE-WITH-FERNET

# ---------------------------------------------------------------
# OAuth providers (fill when ready to integrate)
# ---------------------------------------------------------------
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
